# Copia este archivo como .env y agrega tu API key de Anthropic
# Obtén una en: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_KEY=sk-ant-api03-...

# ── Servidor (Render env vars, NO llevan prefijo VITE_) ──
# Postgres de Lukero (Render > Database > Internal Database URL)
DATABASE_URL=postgres://...

# ── Fase 1 · integración con Plaza ──
# URL del proyecto Supabase de Plaza y el secreto compartido del webhook.
PLAZA_SUPABASE_URL=https://TU_PROYECTO_PLAZA.supabase.co
PLAZA_WEBHOOK_SECRET=el_mismo_secreto_que_en_plaza
# Secreto para disparar el barrido de mora desde un scheduler externo.
CRON_SECRET=genera_un_secreto_aqui
